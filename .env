# ============================================================
# AI Engineering OS - Environment Variables
# ============================================================

# -------------------- App --------------------
APP_NAME=AI Engineering OS
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# -------------------- API Keys --------------------
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# -------------------- PostgreSQL --------------------
POSTGRES_USER=aios
POSTGRES_PASSWORD=aios
POSTGRES_DB=aios
DATABASE_URL=postgresql://aios:aios@localhost:5432/aios

# -------------------- Redis --------------------
REDIS_URL=redis://localhost:6379
REDIS_CHANNEL_TASKS=tasks
REDIS_CHANNEL_EVENTS=events

# -------------------- Temporal --------------------
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# -------------------- ChromaDB --------------------
CHROMA_DB_PATH=./memory/chroma_db
VECTOR_EMBEDDING_MODEL=all-MiniLM-L6-v2

# -------------------- Docker --------------------
DOCKER_HOST=unix://var/run/docker.sock
DOCKER_NETWORK=aios_network
DOCKER_TIMEOUT=300
SANDBOX_BASE_IMAGE=python:3.11-slim

# -------------------- Git --------------------
GIT_DEFAULT_BRANCH=main

# -------------------- Security --------------------
SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -------------------- System Limits --------------------
MAX_PARALLEL_AGENTS=3
MAX_RETRY_ATTEMPTS=2
MAX_COST_PER_RUN=5.0
MAX_RUNTIME_PER_TASK=15
CONTEXT_WINDOW_BUDGET=200000
HUMAN_APPROVAL_ENABLED=true

# -------------------- Context Compression --------------------
MAX_CONTEXT_FILES=20
MAX_CONTEXT_TOKENS=50000

# -------------------- Evaluation --------------------
MIN_EVALUATION_SCORE=8.0

# -------------------- Observability --------------------
ENABLE_TRACING=true
ENABLE_METRICS=true

# -------------------- Logging --------------------
LOG_LEVEL=INFO
LOG_FILE=logs/system.log

# -------------------- Monitoring --------------------
PROMETHEUS_PORT=9090
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
